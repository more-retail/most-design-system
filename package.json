{
  "name": "most-design-system",
  "version": "0.10.0",
  "description": "A design system crafted for more retail's digital product ecosystem.",
  "keywords": [
    "design at more",
    "design system",
    "design tokens",
    "more",
    "more design",
    "more retail",
    "most design",
    "most design system"
  ],
  "homepage": "https://github.com/more-retail/most-design-system/",
  "bugs": {
    "url": "https://github.com/more-retail/most-design-system/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Abhishek Rein",
    "email": "w@abhishekrein.xyz",
    "url": "https://abhishekrein.xyz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/more-retail/most-design-system.git"
  },
  "files": [
    "./dist/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/most-design-system.js",
      "types": "./dist/most-design-system.d.ts"
    },
    "./components/react": {
      "import": "./dist/most-design-system.js",
      "types": "./dist/most-design-system.d.ts"
    },
    "./tokens/js": {
      "import": "./dist/tokens/js/tokens.js",
      "types": "./dist/tokens/js/tokens.d.ts"
    },
    "./tokens/react-native": {
      "import": "./dist/tokens/react-native/tokens.js",
      "types": "./dist/tokens/react-native/tokens.d.ts"
    },
    "./tokens/css": "./dist/tokens/css/tokens.css",
    "./tokens/css-in-js": {
      "import": "./dist/tokens/css-in-js/tokens.js",
      "types": "./dist/tokens/css-in-js/tokens.d.ts"
    },
    "./tokens/tailwind": "./dist/tokens/tailwind/tokens.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pnpm build:lib && pnpm build:tokens && pnpm build:storybook",
    "build:lib": "vite build",
    "build:tokens": "vite-node ./style-dictionary/build-tokens.ts",
    "build:storybook": "pnpm build:tokens && storybook build",
    "dev": "vite",
    "dev:storybook": "pnpm build:tokens && storybook dev -p ${PORT:-6006} --no-open",
    "prepare": "husky && pnpm build",
    "lint": "oxlint .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@more-retail/fonts": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@material-symbols/svg-700": "^0.45.5",
    "@microsoft/api-extractor": "^7.58.9",
    "@somehow-digital/commitlint-plugin-spellcheck": "^1.2.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "commitlint-plugin-tense": "^1.0.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "rollup-preserve-directives": "^1.1.3",
    "storybook": "^10.4.6",
    "style-dictionary": "^5.5.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "unplugin-dts": "^1.0.3",
    "vite": "^8.1.2",
    "vite-node": "^6.0.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.12"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0"
    }
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
